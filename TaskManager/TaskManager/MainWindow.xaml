<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
        Padding="15"
        BorderBrush="Gray"
        BorderThickness="1"
        CornerRadius="5">

            <StackPanel>
                <TextBlock
                Text="할 일 등록"
                FontSize="22"
                FontWeight="Bold"
                Margin="0,0,0,15" />

                <TextBlock Text="제목" />

                <TextBox
                Height="30"
                Margin="0,5,0,10"
                Text="{Binding Title,
                    UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="설명" />

                <TextBox
                Height="60"
                Margin="0,5,0,10"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Text="{Binding Description,
                    UpdateSourceTrigger=PropertyChanged}" />

                <Button
                Content="등록"
                Width="100"
                Height="32"
                HorizontalAlignment="Right"
                Command="{Binding AddCommand}" />
            </StackPanel>
        </Border>

        <StackPanel
    Grid.Row="2"
    Orientation="Horizontal"
    HorizontalAlignment="Right">

            <TextBlock
        Text="상태"
        Margin="0,0,8,0"
        VerticalAlignment="Center" />

            <ComboBox
        Width="100"
        ItemsSource="{Binding Filters}"
        SelectedItem="{Binding SelectedFilter, Mode=TwoWay}" />
        </StackPanel>

        <DataGrid
    Grid.Row="4"
    ItemsSource="{Binding TaskItems}"
    SelectedItem="{Binding SelectedTaskItem, Mode=TwoWay}"
    AutoGenerateColumns="False"
    IsReadOnly="True"
    CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn
                Header="번호"
                Width="70"
                Binding="{Binding Id}" />

                <DataGridTextColumn
                Header="제목"
                Width="180"
                Binding="{Binding Title}" />

                <DataGridTextColumn
                Header="설명"
                Width="*"
                Binding="{Binding Description}" />

                <DataGridCheckBoxColumn
                Header="완료"
                Width="70"
                Binding="{Binding IsCompleted}" />

                <DataGridTextColumn
                Header="등록일"
                Width="160"
                Binding="{Binding CreatedAt,
                    StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel
    Grid.Row="6"
    HorizontalAlignment="Right"
    Orientation="Horizontal">

            <Button
        Width="80"
        Height="32"
        Margin="0,0,10,0"
        Content="수정"
        Command="{Binding StartEditCommand}" />

            <Button
        Width="80"
        Height="32"
        Margin="0,0,10,0"
        Content="수정 저장"
        Command="{Binding SaveEditCommand}" />

            <Button
        Width="80"
        Height="32"
        Margin="0,0,10,0"
        Content="취소"
        Command="{Binding CancelEditCommand}" />

            <Button
        Width="120"
        Height="32"
        Margin="0,0,10,0"
        Content="완료 상태 변경"
        Command="{Binding ToggleCompletionCommand}" />

            <Button
        Width="80"
        Height="32"
        Content="삭제"
        Command="{Binding DeleteCommand}" />
        </StackPanel>
    </Grid>
</Window>
