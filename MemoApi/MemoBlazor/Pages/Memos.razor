@page "/memos"
@using MemoBlazor.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>메모 관리</PageTitle>

<h1>메모 관리</h1>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5">새 메모 등록</h2>

        <EditForm Model="createRequest"
                  OnValidSubmit="CreateMemoAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label" for="title">
                    제목
                </label>

                <InputText id="title"
                           class="form-control"
                           @bind-Value="createRequest.Title" />

                <ValidationMessage For="@(() => createRequest.Title)" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="category">
                    카테고리
                </label>

                <InputText id="category"
                           class="form-control"
                           @bind-Value="createRequest.Category" />

                <ValidationMessage For="@(() => createRequest.Category)" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="content">
                    내용
                </label>

                <InputTextArea id="content"
                               class="form-control"
                               rows="5"
                               @bind-Value="createRequest.Content" />

                <ValidationMessage For="@(() => createRequest.Content)" />
            </div>

            <button type="submit"
                    class="btn btn-primary"
                    disabled="@isSubmitting">
                @(isSubmitting ? "등록 중..." : "등록")
            </button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(createMessage))
        {
            <div class="alert alert-success mt-3 mb-0">
                @createMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(createErrorMessage))
        {
            <div class="alert alert-danger mt-3 mb-0">
                @createErrorMessage
            </div>
        }
    </div>
</div>


@if (editingMemoId != null)
{
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="h5">메모 수정</h2>

                <EditForm Model="updateRequest"
                          OnValidSubmit="UpdateMemoAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">제목</label>
                        <InputText class="form-control"
                                   @bind-Value="updateRequest.Title" />
                        <ValidationMessage For="@(() => updateRequest.Title)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">카테고리</label>
                        <InputText class="form-control"
                                   @bind-Value="updateRequest.Category" />
                        <ValidationMessage For="@(() => updateRequest.Category)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">내용</label>
                        <InputTextArea class="form-control"
                                       rows="5"
                                       @bind-Value="updateRequest.Content" />
                        <ValidationMessage For="@(() => updateRequest.Content)" />
                    </div>

                    <button type="submit"
                            class="btn btn-primary me-2"
                            disabled="@isUpdating">
                        @(isUpdating ? "수정 중..." : "수정 저장")
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            @onclick="CancelEdit">
                        취소
                    </button>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(updateErrorMessage))
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        @updateErrorMessage
                    </div>
                }
            </div>
        </div>
}

<h2 class="h4">메모 목록</h2>

@if (!string.IsNullOrWhiteSpace(deleteMessage))
{
    <div class="alert alert-success">
        @deleteMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(deleteErrorMessage))
{
    <div class="alert alert-danger">
        @deleteErrorMessage
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">검색어</label>
                <InputText class="form-control"
                           @bind-Value="keyword"
                           placeholder="제목 또는 내용 검색" />
            </div>

            <div class="col-md-3">
                <label class="form-label">카테고리</label>
                <InputText class="form-control"
                           @bind-Value="category"
                           placeholder="전체 카테고리" />
            </div>

            <div class="col-md-3">
                <label class="form-label">정렬</label>
                <InputSelect class="form-select" @bind-Value="sort">
                    <option value="latest">최신순</option>
                    <option value="oldest">오래된순</option>
                    <option value="title">제목 오름차순</option>
                    <option value="title-desc">제목 내림차순</option>
                </InputSelect>
            </div>

            <div class="col-md-2">
                <button type="button"
                        class="btn btn-primary w-100"
                        @onclick="SearchAsync">
                    검색
                </button>
            </div>
        </div>

        <div class="mt-2">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    @onclick="ResetSearchAsync">
                검색 초기화
            </button>
        </div>
    </div>
</div>

@if (isLoading)
{
    <p>메모를 불러오는 중입니다.</p>
}
else if (!string.IsNullOrWhiteSpace(loadErrorMessage))
{
    <div class="alert alert-danger">
        @loadErrorMessage
    </div>
}
else if (result == null || result.Items.Count == 0)
{
    if (!string.IsNullOrWhiteSpace(keyword) ||
        !string.IsNullOrWhiteSpace(category))
    {
        <p>검색 조건에 맞는 메모가 없습니다.</p>
    }
    else
    {
        <p>등록된 메모가 없습니다.</p>
    }
}
else
{
    <p>전체 @(result.TotalCount)개</p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>번호</th>
                <th>제목</th>
                <th>카테고리</th>
                <th>내용</th>
                <th>작성일</th>
                <th>관리</th>
            </tr>
        </thead>

        <tbody>
            @foreach (MemoResponse memo in result.Items)
            {
                <tr>
                    <td>@memo.Id</td>
                    <td>@memo.Title</td>
                    <td>@memo.Category</td>
                    <td>@memo.Content</td>
                    <td>
                        @memo.CreatedAt
                        .ToLocalTime()
                        .ToString("yyyy-MM-dd HH:mm")
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => StartEdit(memo)">
                            수정
                        </button>
                        <button class="btn btn-sm btn-outline-danger ms-2"
                                disabled="@(deletingMemoId != null)"
                                @onclick="() => DeleteMemoAsync(memo)">
                            @(deletingMemoId == memo.Id ? "삭제 중..." : "삭제")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (result.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center">
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@(isLoading || result.Page <= 1)"
                    @onclick="PreviousPageAsync">
                이전
            </button>

            <span>
                @(result.Page) / @(result.TotalPages) 페이지
            </span>

            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@(isLoading || result.Page >= result.TotalPages)"
                    @onclick="NextPageAsync">
                다음
            </button>
        </div>
    }
}

@code {
    private PagedResponse<MemoResponse>? result;
    private MemoCreateRequest createRequest = new();

    private bool isLoading = true;
    private bool isSubmitting;

    private string loadErrorMessage = "";
    private string createErrorMessage = "";
    private string createMessage = "";

    private long? editingMemoId;
    private MemoUpdateRequest updateRequest = new();
    private bool isUpdating;
    private string updateErrorMessage = "";

    private long? deletingMemoId;
    private string deleteErrorMessage = "";
    private string deleteMessage = "";

    private string keyword = "";
    private string category = "";
    private string sort = "latest";
    private int currentPage = 1;
    private int pageSize = 5;

    protected override async Task OnInitializedAsync()
    {
        await LoadMemosAsync();
    }

    private async Task LoadMemosAsync()
    {
        try
        {
            isLoading = true;
            loadErrorMessage = "";

            string requestUrl =
                $"/api/memos?page={currentPage}&pageSize={pageSize}&sort={sort}";

            if (!string.IsNullOrWhiteSpace(keyword))
            {
                requestUrl +=
                    $"&keyword={Uri.EscapeDataString(keyword.Trim())}";
            }

            if (!string.IsNullOrWhiteSpace(category))
            {
                requestUrl +=
                    $"&category={Uri.EscapeDataString(category.Trim())}";
            }

            result = await Http.GetFromJsonAsync<PagedResponse<MemoResponse>>(
                requestUrl);
        }
        catch (HttpRequestException exception)
        {
            loadErrorMessage =
                $"API 연결에 실패했습니다: {exception.Message}";
        }
        catch (Exception exception)
        {
            loadErrorMessage =
                $"메모 조회 중 오류가 발생했습니다: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateMemoAsync()
    {
        try
        {
            isSubmitting = true;
            createMessage = "";
            createErrorMessage = "";
            deleteMessage = "";
            deleteErrorMessage = "";

            HttpResponseMessage response =
                await Http.PostAsJsonAsync(
                    "/api/memos",
                    createRequest);

            if (!response.IsSuccessStatusCode)
            {
                string responseBody =
                    await response.Content.ReadAsStringAsync();

                createErrorMessage =
                    $"등록에 실패했습니다. {responseBody}";

                return;
            }

            createMessage = "메모가 등록되었습니다.";
            createRequest = new MemoCreateRequest();

            currentPage = 1;
            await LoadMemosAsync();
        }
        catch (HttpRequestException exception)
        {
            createErrorMessage =
                $"API 연결에 실패했습니다: {exception.Message}";
        }
        catch (Exception exception)
        {
            createErrorMessage =
                $"메모 등록 중 오류가 발생했습니다: {exception.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void StartEdit(MemoResponse memo)
    {
        editingMemoId = memo.Id;

        updateRequest = new MemoUpdateRequest
        {
            Title = memo.Title,
            Content = memo.Content,
            Category = memo.Category
        };

        updateErrorMessage = "";
    }

    private void CancelEdit()
    {
        editingMemoId = null;
        updateRequest = new MemoUpdateRequest();
        updateErrorMessage = "";
    }

    private async Task UpdateMemoAsync()
    {
        if (editingMemoId == null)
        {
            return;
        }

        try
        {
            isUpdating = true;
            updateErrorMessage = "";
            createMessage = "";
            deleteMessage = "";
            deleteErrorMessage = "";

            HttpResponseMessage response = await Http.PutAsJsonAsync(
                $"/api/memos/{editingMemoId}",
                updateRequest);

            if (!response.IsSuccessStatusCode)
            {
                string responseBody =
                    await response.Content.ReadAsStringAsync();

                updateErrorMessage =
                    $"수정에 실패했습니다. {responseBody}";

                return;
            }

            createMessage = "메모가 수정되었습니다.";

            CancelEdit();
            await LoadMemosAsync();
        }
        catch (HttpRequestException exception)
        {
            updateErrorMessage =
                $"API 연결에 실패했습니다: {exception.Message}";
        }
        catch (Exception exception)
        {
            updateErrorMessage =
                $"메모 수정 중 오류가 발생했습니다: {exception.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task DeleteMemoAsync(MemoResponse memo)
    {
        bool confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"'{memo.Title}' 메모를 삭제하시겠습니까?");

        if (!confirmed)
        {
            return;
        }

        try
        {
            isDeleting = true;
            deleteMessage = "";
            deleteErrorMessage = "";
            createMessage = "";

            HttpResponseMessage response =
                await Http.DeleteAsync($"/api/memos/{memo.Id}");

            if (!response.IsSuccessStatusCode)
            {
                string responseBody =
                    await response.Content.ReadAsStringAsync();

                deleteErrorMessage =
                    $"삭제에 실패했습니다. {responseBody}";

                return;
            }

            if (editingMemoId == memo.Id)
            {
                CancelEdit();
            }

            deleteMessage = "메모가 삭제되었습니다.";

            await LoadMemosAsync();

            if (result != null &&
                result.Items.Count == 0 &&
                currentPage > 1)
            {
                currentPage--;
                await LoadMemosAsync();
            }
        }
        catch (HttpRequestException exception)
        {
            deleteErrorMessage =
                $"API 연결에 실패했습니다: {exception.Message}";
        }
        catch (Exception exception)
        {
            deleteErrorMessage =
                $"메모 삭제 중 오류가 발생했습니다: {exception.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private async Task SearchAsync()
    {
        currentPage = 1;
        await LoadMemosAsync();
    }

    private async Task ResetSearchAsync()
    {
        keyword = "";
        category = "";
        sort = "latest";
        currentPage = 1;

        await LoadMemosAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (currentPage <= 1)
        {
            return;
        }

        currentPage--;
        await LoadMemosAsync();
    }

    private async Task NextPageAsync()
    {
        if (result == null || currentPage >= result.TotalPages)
        {
            return;
        }

        currentPage++;
        await LoadMemosAsync();
    }
}